# Secrets — NEVER commit
.env
.env.local
# .env.example is a committed template (placeholder values only — no real keys)

# Local runtime state — regenerated on each run
code/state/sessions/*/
!code/state/sessions/.gitkeep
code/sandbox/*.txt
code/.venv/
gateway/.venv/
gateway/*.db
gateway/usage.json

# Build / cache artifacts
**/__pycache__/
**/*.pyc
**/uv.lock
**/.pytest_cache/

# Editors
.vscode/
.idea/
.DS_Store
