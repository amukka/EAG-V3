{
  "manifest_version": 3,
  "name": "RAG Indexer",
  "version": "1.0",
  "description": "Send local files and web pages to your local RAG agent for indexing.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5050/*",
    "http://127.0.0.1:5050/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
